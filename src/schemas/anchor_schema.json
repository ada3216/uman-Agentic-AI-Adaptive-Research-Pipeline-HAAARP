{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Pass 1 Anchor Record",
  "type": "object",
  "required": [
    "pass1_hash",
    "artifact_path",
    "timestamp_utc",
    "strand",
    "anchor_type",
    "anchor_value"
  ],
  "properties": {
    "pass1_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifact_path": {
      "type": "string"
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "operator_id": {
      "type": ["string", "null"]
    },
    "pre_registration_doi": {
      "type": ["string", "null"]
    },
    "strand": {
      "type": "string",
      "enum": ["IPA", "PDA", "TA", "quant", "mixed"]
    },
    "anchor_type": {
      "type": "string",
      "enum": ["local", "osf_doi", "repo_accession"]
    },
    "anchor_value": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}